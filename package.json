{
  "name": "helix",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "setup": "node scripts/setup.mjs",
    "demo": "node scripts/demo.mjs",
    "n8n:ping": "node --env-file=.env scripts/n8n-sync.mjs ping",
    "n8n:list": "node --env-file=.env scripts/n8n-sync.mjs list",
    "n8n:push": "node --env-file=.env scripts/n8n-sync.mjs push",
    "n8n:sync": "node --env-file=.env scripts/n8n-sync.mjs sync"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "8.61.0",
    "@typescript-eslint/parser": "8.61.0",
    "eslint": "10.5.0",
    "prettier": "3.8.4",
    "turbo": "2.9.18",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=20"
  }
}
