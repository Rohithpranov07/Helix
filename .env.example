# ---- AI (Cognition + Perception) ----
GROQ_API_KEY=               # gsk_... Groq token; serves Qwen3.6-27B (primary LLM)
GROQ_BASE_URL=              # optional override (default https://api.groq.com/openai/v1)
GROQ_MODEL=                 # optional override (default qwen/qwen3.6-27b)
GEMINI_API_KEY=
HELIX_SOVEREIGN=0           # 1 = route reasoning to local open-weight endpoint
HELIX_SOVEREIGN_BASE=       # used when HELIX_SOVEREIGN=1
EMBEDDING_PROVIDER=gemini   # gemini | local — isolate behind embed()

# ---- Biology / memory ----
MONGODB_URI=                # mongodb+srv://<user>:<pass>@cluster.mongodb.net/?appName=...
MONGODB_DB=helix

# ---- Target (the "patient") + Shadow ----
TARGET_APP_URL=http://localhost:3001
SHADOW_APP_URL=http://localhost:3002
TARGET_ALLOWLIST=http://localhost:3001,http://localhost:3002   # scanner gate

# ---- Supabase (ShopLite target backend) ----
NEXT_PUBLIC_SUPABASE_URL=           # https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=   # sb_publishable_...
SUPABASE_SERVICE_KEY=               # service_role key — server-side only, never NEXT_PUBLIC_

# ---- Orchestration + control plane ----
N8N_WEBHOOK_BASE=http://localhost:5678/webhook
HELIX_API_BASE=http://localhost:3000
N8N_ENCRYPTION_KEY=           # openssl rand -hex 16

# ---- n8n Cloud Public API (workflow-as-code sync) ----
N8N_API_URL=                  # https://<your-instance>.app.n8n.cloud  (no trailing slash)
N8N_API_KEY=                  # n8n cloud Public API key (Settings → n8n API). NEVER commit the real value.

# ---- GitHub Genome (repository drift monitor) ----
GITHUB_CLIENT_ID=             # From GitHub Developer Settings → OAuth Apps → Client ID
GITHUB_CLIENT_SECRET=         # From GitHub Developer Settings → OAuth Apps → Client Secret
GITHUB_CALLBACK_URL=http://localhost:3000/api/auth/github/callback  # Must match OAuth app "Authorization callback URL"
